# RAG Bot API - Environment Configuration Example
# Copy this file to .env and fill in your values

# LLM Configuration (Required)


# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Model Configuration (Optional)

# Embedding model - lightweight model for fast inference
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM model - supports gpt-3.5-turbo, gpt-4, gpt-4o-mini, etc.
LLM_MODEL=gpt-4o-mini

# Ollama configuration (alternative to OpenAI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Database & Storage Configuration (Optional)

# ChromaDB persistence directory
CHROMA_DB_PATH=./chroma_db

# BM25 index directory
BM25_INDEX_PATH=./bm25_index

# Uploaded files directory
UPLOAD_DIR=./uploads

# Document metadata store file
METADATA_STORE_PATH=./metadata.json

# Collection Names (Optional)

# ChromaDB collection name for storing embeddings
COLLECTION_NAME=pdf-rag-documents

# Retrieval Configuration (Optional)
# Max workers for background tasks (default: 4)
MAX_WORKERS=4

# Logging Configuration (Optional)

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
LOG_FILE=./logs/api.log


# Allowed origins for CORS (comma-separated)
# Leave empty to use defaults: localhost:3000, localhost:8000, localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

